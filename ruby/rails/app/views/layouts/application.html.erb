<!DOCTYPE html>
<html>
  <head>
    <title><%= @page_title || "The Internet Gift Registry" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>
    <meta name="theme-color" content="#ffffff">
    <link rel="icon" href="<%= asset_path("icon-192.png") %>" type="image/png">
    <link rel="apple-touch-icon" href="<%= asset_path("icon-192.png") %>">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%#= stylesheet_link_tag :app, "data-turbo-track": "reload" %>

    <%= stylesheet_link_tag :v1, media: 'all', 'data-turbo-track': 'reload' %>
  </head>

  <body>
    <div id="doc3">
      <div id="hd">
        <%= yield :header %>
      </div>
      <div id="bd">
        <div class="yui-gf">
          <div class="yui-u first">
            <%= render :partial=>"layouts/navigation" if logged_in? %>
            <%= yield :left %>
          </div>
          <div class="yui-u">
            <%= render :partial=>"layouts/flashes" %>
            <%= yield %>
          </div>
        </div>
      </div>
      <div id="ft">
        <%= render :partial=>"layouts/footer" %>
        <%= yield :footer %>
      </div>
    </div>
    <%= javascript_include_tag 'pwa-global', 'data-turbo-track': 'reload' %>
  </body>
</html>
